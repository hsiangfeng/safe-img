{
  "name": "safe-img",
  "version": "0.1.0",
  "description": "Framework-agnostic broken-image fallback with retry, LRU failed-URL cache, and an optional YouTube-style blurred backdrop. Programmatic API, data-attribute auto-init, and a <safe-img> Web Component.",
  "license": "MIT",
  "author": "hsiangfeng <israynotarray@gmail.com>",
  "homepage": "https://github.com/hsiangfeng/safe-img#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsiangfeng/safe-img.git"
  },
  "bugs": {
    "url": "https://github.com/hsiangfeng/safe-img/issues"
  },
  "funding": [
    {
      "type": "buymeacoffee",
      "url": "https://buymeacoffee.com/israynotarray"
    },
    {
      "type": "portaly",
      "url": "https://portaly.cc/israynotarray/support"
    }
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./global": "./dist/index.global.js"
  },
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "README.zh-TW.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "dev": "vite serve playground"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "packageManager": "pnpm@9.15.0",
  "keywords": [
    "image",
    "img",
    "safe-img",
    "fallback",
    "image-fallback",
    "broken-image",
    "placeholder",
    "blurred-backdrop",
    "echo-pillarboxing",
    "web-component",
    "vanilla-js",
    "react",
    "vue",
    "svelte",
    "framework-agnostic",
    "retry",
    "lazy-loading"
  ]
}
